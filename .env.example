# QuakeBot environment example
#
# Python code in this repo reads process environment variables directly.
# If you use Docker Compose:
# - the backend container may reach Ollama at `http://ollama:11434`

# OpenAI-compatible agent
OPENAI_API_KEY=
# Optional. Defaults to https://api.openai.com/v1
OPENAI_BASE_URL=

# Ollama
# Optional. Defaults to http://localhost:11434 locally.
# In Docker Compose this is often http://ollama:11434
OLLAMA_HOST=
# Optional. Defaults to llama3.1 locally or gpt-oss:120b for cloud mode.
OLLAMA_MODEL=
# Only needed for Ollama Cloud.
OLLAMA_API_KEY=
